# Normalize all text files to LF in the repository.
* text=auto eol=lf

# Explicit text types
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.toml  text eol=lf
*.xml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf

# Binary assets — never normalize
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.webp  binary
